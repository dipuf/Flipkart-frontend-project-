* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

.container {
    min-height: 99.5vh;
    width: auto;
    display: flex;
    justify-content: space-around;
}

.inner {
    min-height: 99.5vh;
    width: 92vw;
}

nav {
    height: 30px;
    width: auto;
    display: flex;
    justify-content: space-between;
    padding-bottom: 35px;
    padding-top: 15px;
    /* position: sticky;
    top: 0;
    z-index: 1000; */
    background-color: white;

}

nav ul {
    display: flex;
}

.btn button {
    height: 50px;
    width: 150px;
    border-radius: 17px;
    font-weight: 550;
    border: none;
    outline: none;
}

.btn button:first-child {
    background-color: yellow;
    margin-right: 15px;
    position: relative;
    font-size: large;
    font-style: oblique;
    
}

.btn button:last-child {
    background-color: rgba(128, 128, 128, 0.267);
    position: relative;
    font-size: large;
    font-style: oblique;
    cursor: pointer;
}

.btn button:first-child img,
.btn button:last-child img {
    position: absolute;
    left: 0;
    bottom: 25%;
    height: 50%;
    margin-left: 10px;
}

.topul {
    margin-right: 100px;
}
.panel{
    position: fixed;
    right: 0;
    top:0;
    width: 34vw;
    height: 100vh;
    z-index: 999;
    background-color:  white;
    display:none;
    
}
.active{
    display: block;
}
.bar{
    width:100%;
    margin-top: 8px;
    height: 4px;
    display: flex;
    justify-content: center;
}
.seek{
    width: 32px;
    height: 90%;
    border-radius: 6px;
    background-color: rgba(128, 128, 128, 0.409);
}
.insidePanel{
    width: 93%;
    height: 80%;
    margin:20px;
    padding: 4px;
    font-family: 'Ballo Bhai 2',sans-serif;
}
.cross{
    display: flex;
    justify-content: space-between;
    margin-top: 10px;
}
.cross img{
    width: 30px;
}
.cross img:hover{
    cursor: pointer;
}

.insidePanel p{
    margin-left: 10px;
    font-weight: 550;
}
.para{
    cursor:default;
}
.para >p:first-child{
    color:blue;
}
.para >p:last-child{
    font-size: small;
    color:rgba(0, 0, 0, 0.721);
}
.autolocation img{
    width: 30px;
}
.autolocation{
    margin-top: 17px;
    display: flex;
}
.line{
  width: auto;
  height: 1px;
  background: repeating-linear-gradient(
    to right,
    rgba(0, 0, 0, 0.514) 0 3px,
    transparent 2px 10px
  );
  margin-top: 20px;
}
.saved{
    display: flex;
    margin-top: 20px;
    align-items: center;
    cursor: pointer;
}
.insidePanel h4{
    margin-top: 20px;
    cursor: default;
}
.saved img{
    width:25px;
}
.saved >p{
    font-size:medium;
    color: blue;
}
.inputcontain{
    width: 100%;
    height: 50px;
    border: 1px solid grey;
    margin-top: 20px;
    border-radius: 10px;
    border-bottom: 3px solid rgba(128, 128, 128, 0.382);
}   
.inputcontain >img{
    height: 20px;
    width:20px;
    margin: 14px 0;
    margin-left: 8px;
}
.panel input{
    position: relative;
    left:15px;
    width:85%;
    height: 90%;
    border: none;
    outline: none;
    bottom: 20px;
}

nav ul li {
    list-style: none;
    margin-top: 10px;
    position: relative;
    margin-right: 10px;
}

nav ul li:first-child::before {
    content: "";
    height: 20px;
    width: 20px;
    position: absolute;
    background-image: url("location.svg");
    left: -25px;
    background-size: contain;
    background-repeat: no-repeat;
}

nav ul li:last-child {
    color: blue;
    font-weight: 600;
    position: relative;
}

nav ul li:last-child::after {
    background-image: url("https://ico.hugeicons.com/arrow-right-01-stroke-rounded@2x.webp?v=1.0.0");
    height: 20px;
    width: 20px;
    position: absolute;
    content: "";
    background-size: contain;
    background-repeat: no-repeat;
}

.detail {
    width: auto;
    height: 50px;
    margin-bottom: 10px;
    margin-top: 30px;
    display: flex;
    justify-content: space-between;
    background-color: white;
}

.search {
    height: 50px;
    width: 980px;
    border-radius: 15px;
    border: 2px solid rgb(61, 184, 232);
    outline: none;
    display: flex;
    gap: 40px;
    position: relative;
    margin-left: 10px;
    margin-right: 10px;
}

.search img {
    position: absolute;
    height: 27px;
    top: 18%;
    left: 10px;
    margin: 0 5px;
}

.search input {
    margin-left: 50px;
    margin-top: 4px;
    margin-bottom: 6px;
    height: 80%;
    width: 85%;
    border: none;
    outline: none;
    line-height: 90px;
    font-size: 18px;
    
}
.input{
    width: 100%;
    position: relative;
}
.history{
    min-height: 75vh;
    width: 960px;
    z-index: 999;
    background-color: white;
    position: absolute;
    border-radius: 15px;
    top:48px;
    left: 10px;
    border: 2px solid whitesmoke;
    padding: 20px 15px;
    display: none;
}
.history.active{
    display: block;
}
.innerhistory ul{
    list-style: none;

}
.innerhistory ul >p{
    color:grey;
}
.innerhistory ul li:nth-child(1),.innerhistory ul li:nth-child(2),.innerhistory ul li:nth-child(3){
    background-image: url("https://rukminim2.flixcart.com/www/100/100/promos/19/07/2018/321e89f8-9ffa-47a7-a9d4-731da9bde6c4.png?q=90");  
    background-repeat: no-repeat;

}
.innerhistory ul li{
  background-image:url("https://rukminim1.flixcart.com/www/100/100/promos/20/07/2022/ea2077a7-575d-4fb9-a4dd-6df16e53c5d8.png?q=90");
background-size:25px 25px;
background-repeat: no-repeat;
background-position: left center;
color:rgba(0, 0, 0, 0.759);
padding-left: 40px;
margin: 8px 0;
    
}


.list>ul {
    display: flex;
    gap: 50px;
    margin-top: 15px;
    position: relative;
}

.list>ul li{
    list-style: none;
    margin-right: 10px;
    font-size: 20px;
    color: rgba(0, 0, 0, 0.753);
    list-style-position: inside;
    cursor:pointer;
}

.list ul li:nth-child(1):before,.list ul li:nth-child(3)::before{
    content: "";
    position: absolute;
    left: -30px;
    top: 2px;
    width: 20px;
    height: 20px;
    background-image: url("https://static-assets-web.flixcart.com/batman-returns/batman-returns/p/images/profile-6bae67.svg");
    background-size: contain;
    background-repeat: no-repeat;
}
.list ul li:nth-child(1)::after,
.list ul li:nth-child(2)::after {
    content: "";
    position: absolute;
    top: 2px;
    width: 20px;
    height: 20px;
    background-image: url("https://ico.hugeicons.com/arrow-down-01-stroke-rounded@2x.webp?v=1.0.0");
    background-size: contain;
    background-repeat: no-repeat;
}
.list ul li:nth-child(1):hover::after,
.list ul li:nth-child(2):hover::after{
    transform:rotate(180deg);


}

.list ul li:last-child {
    position: relative;
}

.list ul li:last-child::before {
    content: "";
    position: absolute  ;
    top: 2px;
    width: 20px;
    height: 20px;
    background-image: url("https://static-assets-web.flixcart.com/batman-returns/batman-returns/p/images/header_cart_v4-6ac9a8.svg");
    background-size: contain;
    background-repeat: no-repeat;
}


